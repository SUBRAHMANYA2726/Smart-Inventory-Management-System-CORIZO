# ─────────────────────────────────────────────────────────
#  Smart Inventory Management System — Environment Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# Leave MONGODB_URI blank to use the local SQLite database (default).
# Fill in to use MongoDB Atlas cloud storage instead.
MONGODB_URI=

# MongoDB settings (only used when MONGODB_URI is set)
MONGODB_DATABASE=ECOM
MONGODB_COLLECTION=items

# ── Flask ─────────────────────────────────────────────────
# Set to "production" before deploying publicly
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string
